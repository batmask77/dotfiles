[safe]
	directory = /mnt/NVMe M.2/output_files/\n
	directory = *
[user]
	name = batmask
	email = batmask@naver.com
[core]
	autocrlf = input
	editor = vim
[diff]
	tool = meld
[difftool]
	prompt = false
[init]
	defaultBranch = main
[cola]
	startupmode = folder
[difftool "meld"]
	cmd = meld \"$LOCAL\" \"$REMOTE\"
[merge]
	tool = meld
[mergetool "meld"]
	cmd = meld \"$LOCAL\" \"$BASE\" \"$REMOTE\" --output \"$MERGED\"
[mergetool]
	keepBackup = false
